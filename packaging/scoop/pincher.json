                "hash": {
                    "url": "https://github.com/kwad77/pincher/releases/download/v$version/SHA256SUMS",
                    "regex": "([a-f0-9]{64})\\s+pincher-v$version-windows-amd64\\.zip"
                },
                "bin": [
                    ["pincher-v$version-windows-amd64.exe", "pincher"]
                ]
            },
            "arm64": {
                "url": "https://github.com/kwad77/pincher/releases/download/v$version/pincher-v$version-windows-arm64.zip",
